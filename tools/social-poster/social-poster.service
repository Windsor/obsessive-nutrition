[Unit]
Description=Social Auto-Poster for The Portugal Brief
After=network.target ghost-portugal.service

[Service]
Type=simple
User=windsor1337
WorkingDirectory=/opt/social-poster
EnvironmentFile=/opt/social-poster/.env
ExecStart=/opt/social-poster/venv/bin/gunicorn -b 127.0.0.1:5555 -w 2 app:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
